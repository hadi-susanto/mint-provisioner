# ------------------------------------------------------------------
# Window behavior
# ------------------------------------------------------------------

# Theme
theme = GitHub Dark

# Never restore previous tabs/splits/windows
# (works on macOS, ignored on Linux)
window-save-state = never

# ------------------------------------------------------------------
# Split creation
# ------------------------------------------------------------------

# Split right
keybind = ctrl+shift+e=new_split:right

# Split down
keybind = ctrl+shift+o=new_split:down

# Automatic split direction
keybind = ctrl+shift+enter=new_split:auto

# ------------------------------------------------------------------
# Split navigation
# ------------------------------------------------------------------

keybind = ctrl+left=goto_split:left
keybind = ctrl+right=goto_split:right
keybind = ctrl+up=goto_split:top
keybind = ctrl+down=goto_split:bottom

# ------------------------------------------------------------------
# Split zoom (similar to tmux prefix+z)
# ------------------------------------------------------------------

keybind = ctrl+shift+x=toggle_split_zoom
